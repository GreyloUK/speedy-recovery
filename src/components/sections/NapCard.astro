---
import { business } from "../../data";
import type { Location } from "../../data/locations";
import Icon from "../ui/Icon.astro";

interface Props {
  location: Location;
}

const { location } = Astro.props;

const headlineAddress = `${location.address.street}, ${location.name} ${location.address.postcode}`;
const postcodeIsTk = location.address.postcode.startsWith("[TK");
const emailIsTk = business.email.general.startsWith("[TK");

const intro =
  location.napIntro ??
  `Our ${location.name} base serves ${location.address.postcode} and the surrounding postcodes — a typical response of ${location.responseMinutes} minutes, 24 hours a day.`;

// Placeholder Google Maps query — falls back to name+locality when the postcode
// is still a [TK] draft so the embed resolves to something meaningful.
const mapParts = [
  location.address.street,
  location.address.locality,
  postcodeIsTk ? null : location.address.postcode,
].filter(Boolean) as string[];
const mapQuery = mapParts.join(", ");
const mapEmbedSrc = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`;
const gbpHref =
  location.gbpUrl ??
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapQuery)}`;
---

<section class="nap">
  <div class="container-page nap__inner">
    <article class="nap__card">
      <header class="nap__head">
        <span class="section-label">Our {location.name} base</span>
        <h2>{headlineAddress}</h2>
        <p class="nap__intro">{intro}</p>
      </header>

      <dl class="nap__meta">
        <div class="nap__row">
          <dt>Address</dt>
          <dd>
            <address>
              <strong>{business.name}</strong><br />
              {location.address.street}<br />
              {location.address.locality}<br />
              {location.address.region}
              <span class:list={[postcodeIsTk && "tk"]}>
                {location.address.postcode}
              </span>
            </address>
          </dd>
        </div>

        <div class="nap__row nap__row--split">
          <div>
            <dt>Phone</dt>
            <dd>
              <a href={business.phone.href} class="nap__tel">
                {business.phone.display}
              </a>
            </dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd>
              {emailIsTk ? (
                <span class="tk">{business.email.general}</span>
              ) : (
                <a href={business.email.href} class="nap__email">
                  {business.email.general}
                </a>
              )}
            </dd>
          </div>
        </div>

        <div class="nap__row">
          <dt>Opening hours</dt>
          <dd class="nap__hours">
            <span class="nap__hours-dot" aria-hidden="true"></span>
            <span>{business.hours.label}</span>
          </dd>
        </div>
      </dl>
    </article>

    <aside class="nap__map" aria-label={`${location.name} location on Google Maps`}>
      <div class="nap__map-frame">
        <iframe
          src={mapEmbedSrc}
          title={`Map showing ${business.name} in ${location.name}`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <a
        href={gbpHref}
        class="nap__gbp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="nap__gbp-icon" aria-hidden="true">
          <Icon name="google" size={18} />
        </span>
        <span class="nap__gbp-text">
          <span class="nap__gbp-label">View us on</span>
          <span class="nap__gbp-name">Google Maps</span>
        </span>
        <span class="nap__gbp-arrow" aria-hidden="true">
          <Icon name="arrow-right" size={16} />
        </span>
      </a>
    </aside>
  </div>
</section>

<style>
  .nap {
    background: var(--color-neutral-50);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }
  .nap__inner {
    padding-block: 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* ---- Left: letterhead-style info panel ---- */
  .nap__card {
    background: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nap__head h2 {
    margin-top: 0.5rem;
    font-size: clamp(1.45rem, 2.2vw, 1.95rem);
    line-height: 1.05;
  }

  .nap__intro {
    margin-top: 0.85rem;
    color: var(--color-neutral-700);
    line-height: 1.55;
    font-size: 1rem;
    max-width: 60ch;
  }

  /* Divided-cell meta grid — thin dividers via a 1px background. */
  .nap__meta {
    margin: 0.5rem 0 0;
    display: grid;
    gap: 1px;
    background: var(--color-neutral-200);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .nap__row {
    background: #fff;
    padding: 1rem 1.15rem;
    margin: 0;
  }
  .nap__row--split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-neutral-200);
    padding: 0;
  }
  .nap__row--split > div {
    background: #fff;
    padding: 1rem 1.15rem;
  }

  .nap__meta dt {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-primary-700);
    margin-bottom: 0.35rem;
  }

  .nap__meta dd {
    margin: 0;
    color: var(--color-neutral-900);
    font-size: 1rem;
    line-height: 1.5;
  }
  .nap__meta address {
    font-style: normal;
  }
  .nap__meta address strong {
    display: inline-block;
    margin-bottom: 0.15rem;
    color: var(--color-primary-900);
  }

  .nap__tel,
  .nap__email {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--color-primary-900);
    letter-spacing: -0.005em;
  }
  .nap__email {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary-700);
    word-break: break-all;
  }
  .nap__tel:hover,
  .nap__email:hover {
    color: var(--color-accent-600);
  }

  .nap__hours {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .nap__hours-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-accent-500);
    box-shadow: 0 0 0 3px rgba(255, 176, 41, 0.25);
    flex: none;
  }

  /* ---- Right: Google Maps embed + GBP link ---- */
  .nap__map {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    min-height: 320px;
  }

  .nap__map-frame {
    position: relative;
    flex: 1 1 auto;
    min-height: 260px;
    background: var(--color-neutral-100);
  }
  .nap__map-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .nap__gbp {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.1rem;
    background: #fff;
    color: var(--color-primary-900);
    border-top: 1px solid var(--color-neutral-200);
    transition: background-color 180ms ease, color 180ms ease;
  }
  .nap__gbp:hover { background: var(--color-neutral-50); }
  .nap__gbp:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: -2px;
  }

  .nap__gbp-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    color: var(--color-primary-800);
    flex: none;
  }

  .nap__gbp-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    flex: 1 1 auto;
    min-width: 0;
  }
  .nap__gbp-label {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-neutral-600);
  }
  .nap__gbp-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-primary-900);
    letter-spacing: -0.005em;
    margin-top: 0.2rem;
  }

  .nap__gbp-arrow {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary-700);
    flex: none;
    transition: color 180ms ease;
  }
  .nap__gbp:hover .nap__gbp-arrow { color: var(--color-accent-600); }

  /* ---- Responsive ---- */
  @media (min-width: 640px) {
    .nap__row--split { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 900px) {
    .nap__inner {
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
      gap: 1.5rem;
    }
    .nap__card { padding: 2rem 2rem 1.75rem; }
    .nap__map { min-height: 100%; }
    .nap__map-frame { min-height: 340px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nap__gbp,
    .nap__gbp-arrow {
      transition: none;
    }
  }
</style>
