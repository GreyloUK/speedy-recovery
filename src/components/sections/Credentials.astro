---
import { credentials } from "../../data";
import type { Credential } from "../../data/credentials";
import Icon from "../ui/Icon.astro";
import pas43Logo from "../../assets/images/trust-badges/pas43.svg";
import rhaLogo from "../../assets/images/trust-badges/rha.svg";
import ivrLogo from "../../assets/images/trust-badges/ivr.svg";
import aaLogo from "../../assets/images/trust-badges/aa.svg";
import fmgLogo from "../../assets/images/trust-badges/fmg.svg";

const logoMap: Record<string, { src: string; width: number; height: number }> = {
  pas43: pas43Logo,
  "o-licence": rhaLogo,
  ivr: ivrLogo,
  aa: aaLogo,
  fmg: fmgLogo,
};

const accreditations = credentials.filter((c) => c.category === "accreditation");
const partnerships = credentials.filter((c) => c.category === "partnership");

const groups: { label: string; items: Credential[] }[] = [
  { label: "Accreditations", items: accreditations },
  { label: "Dispatch partnerships", items: partnerships },
];
---

<section class="creds">
  <div class="container-page creds__inner">
    <div class="creds__grid">
      <div class="creds__prose">
        <span class="section-label">Credentials</span>
        <h2>The paperwork insurers, fleets and police pounds check for.</h2>

        <p class="creds__lead">
          PAS43, O-Licence and IVR aren't marketing claims — they're the gate. A
          London vehicle-recovery operator without them can't be on an AA or
          FMG dispatch panel, can't bill an insurer direct on a claim-approved
          recovery, and can't collect a vehicle from a Metropolitan Police
          pound on behalf of the owner. We've held all three for years, which is
          why local garages, brokers and claim handlers trust us with repeat
          work — from North Harrow to the North Circular and every borough
          between.
        </p>

        <p class="creds__body">
          <strong>PAS43 2012</strong> covers the recovery itself — how a vehicle
          is lifted, strapped, transported and delivered. The
          <strong>Operator's Licence</strong> covers how we move vehicles
          commercially under DVSA rules. <strong>IVR certification</strong>
          proves every driver on our rota has been independently assessed on
          the techniques that keep your vehicle — and the road — safe. Add the
          AA and FMG dispatch contracts on top, and you have a recovery
          operator set up to handle insurer, fleet, police and private work
          from the same phone number.
        </p>
      </div>

      <aside class="creds__panel" aria-label="Our accreditations and partnerships">
        <header class="creds__panel-head">
          <span class="creds__panel-label">Certified &middot; Dispatched by</span>
          <span class="creds__panel-stamp" aria-hidden="true">Reg. proof</span>
        </header>

        <div class="creds__panel-body">
          {groups.map((g) => (
            <div class="creds__group">
              <h3 class="creds__group-title">{g.label}</h3>
              <ul class="creds__list">
                {g.items.map((c) => (
                  <li class="creds__row">
                    <div class="creds__icon" aria-hidden="true">
                      {logoMap[c.id] ? (
                        <img src={logoMap[c.id].src} alt="" width="40" height="40" loading="lazy" decoding="async" />
                      ) : (
                        <Icon name={c.iconName} size={32} strokeWidth={1.5} />
                      )}
                    </div>
                    <div class="creds__text">
                      <span class="creds__name">{c.label}</span>
                      <p class="creds__summary">{c.summary}</p>
                      {c.certNumber && (
                        <span class="creds__num">
                          Reg.
                          <span class:list={[c.certNumber.startsWith("[TK") && "tk"]}>
                            {c.certNumber}
                          </span>
                        </span>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <footer class="creds__panel-foot">
          <span>Verified on request — cert copies available to insurer panels and commercial clients.</span>
        </footer>
      </aside>
    </div>
  </div>
</section>

<style>
  .creds {
    background: #fff;
  }
  .creds__inner {
    padding-block: 3.75rem;
  }

  .creds__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    align-items: start;
  }

  /* ----- Left: prose ----- */
  .creds__prose h2 { margin-top: 0.6rem; max-width: 22ch; }
  .creds__lead {
    margin-top: 1rem;
    color: var(--color-neutral-800);
    font-size: 1.0625rem;       /* 17px */
    line-height: 1.6;
    max-width: 58ch;
  }
  .creds__body {
    margin-top: 1.1rem;
    color: var(--color-neutral-700);
    font-size: 1rem;             /* 16px */
    line-height: 1.65;
    max-width: 58ch;
  }
  .creds__body strong {
    color: var(--color-primary-900);
    font-weight: 700;
  }

  /* ----- Right: credentials panel ----- */
  .creds__panel {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .creds__panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--color-neutral-200);
    background: #fff;
  }
  .creds__panel-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;        /* 13px */
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary-700);
  }
  .creds__panel-stamp {
    font-family: var(--font-display);
    font-size: 0.875rem;          /* 14px */
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-600);
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--color-accent-300);
    border-radius: var(--radius-xs);
    background: var(--color-accent-50);
  }

  .creds__panel-body {
    padding: 0.5rem 1.5rem 1.25rem;
  }

  .creds__group + .creds__group {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-neutral-200);
  }

  .creds__group-title {
    font-family: var(--font-sans);
    font-size: 0.8125rem;        /* 13px */
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-neutral-600);
    margin: 1rem 0 0.75rem;
  }

  .creds__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .creds__row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-neutral-200);
  }
  .creds__row:first-child {
    border-top: none;
  }

  .creds__icon {
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-neutral-100);
    border: 1px solid var(--color-neutral-200);
    color: var(--color-primary-900);
    border-radius: var(--radius-sm);
    flex: none;
    padding: 6px;
  }
  .creds__icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .creds__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .creds__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;          /* ~18.4px */
    letter-spacing: -0.005em;
    color: var(--color-primary-900);
    line-height: 1.2;
  }
  .creds__summary {
    margin: 0.1rem 0 0;
    color: var(--color-neutral-700);
    font-size: 1rem;             /* 16px */
    line-height: 1.5;
  }
  .creds__num {
    margin-top: 0.35rem;
    display: inline-flex;
    gap: 0.35rem;
    color: var(--color-neutral-700);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .creds__panel-foot {
    padding: 0.9rem 1.5rem 1rem;
    border-top: 1px solid var(--color-neutral-200);
    background: #fff;
  }
  .creds__panel-foot span {
    display: block;
    font-size: 1rem;
    color: var(--color-neutral-600);
    line-height: 1.5;
    font-style: italic;
  }

  /* ----- Breakpoints ----- */
  @media (min-width: 640px) {
    .creds__inner { padding-block: 4rem; }
  }

  @media (min-width: 960px) {
    .creds__grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.9fr);
      gap: 3rem;
    }
    .creds__inner { padding-block: 4.5rem; }
    .creds__panel-body { padding: 0.5rem 1.75rem 1.5rem; }
    .creds__panel-head,
    .creds__panel-foot { padding-inline: 1.75rem; }
  }

  @media (min-width: 1200px) {
    .creds__grid { gap: 4rem; }
  }
</style>
