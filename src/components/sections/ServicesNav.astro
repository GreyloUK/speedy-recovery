---
import { services } from "../../data";
import type { Service } from "../../data/services";
import Icon from "../ui/Icon.astro";

interface Props {
  heading?: string;
  eyebrow?: string;
  lead?: string;
  filterSlugs?: string[];
  tone?: "light" | "dark";
}

const {
  heading = "Core services. One operator. All 24/7.",
  eyebrow = "What we handle",
  lead,
  filterSlugs,
  tone = "light",
} = Astro.props;

const items: Service[] = filterSlugs
  ? filterSlugs
      .map((slug) => services.find((s) => s.slug === slug))
      .filter((s): s is Service => Boolean(s))
  : [...services];
---

<section class:list={["svc-nav", tone === "dark" && "svc-nav--dark"]}>
  <div class="container-page svc-nav__inner">
    {(eyebrow || heading || lead) && (
      <header class="svc-nav__head">
        {eyebrow && (
          <span class={tone === "dark" ? "section-label-dark" : "section-label"}>
            {eyebrow}
          </span>
        )}
        {heading && <h2>{heading}</h2>}
        {lead && <p class="svc-nav__lead">{lead}</p>}
      </header>
    )}

    <ul class="svc-nav__list" data-count={items.length}>
      {items.map((s) => (
        <li class="svc-nav__item">
          <a href={`/services/${s.slug}/`} class="svc-nav__cell">
            <span class="svc-nav__icon" aria-hidden="true">
              <Icon name={s.iconName} size={22} />
            </span>
            <h3 class="svc-nav__name">{s.name}</h3>
            <p class="svc-nav__tag">{s.shortDescription}</p>
            <span class="svc-nav__arrow" aria-hidden="true">
              <Icon name="arrow-right" size={18} />
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .svc-nav {
    background: #fff;
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }
  .svc-nav--dark {
    background: var(--color-primary-950);
    color: var(--color-neutral-100);
    border-top-color: rgba(255, 255, 255, 0.08);
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .svc-nav__inner {
    padding-block: 2.5rem;
  }
  @media (min-width: 900px) {
    .svc-nav__inner { padding-block: 3rem; }
  }

  .svc-nav__head {
    max-width: 62ch;
    margin-bottom: 1.5rem;
  }
  .svc-nav__head h2 { margin-top: 0.5rem; }
  .svc-nav--dark .svc-nav__head h2 { color: #fff; }

  .svc-nav__lead {
    margin-top: 0.6rem;
    color: var(--color-neutral-700);
    font-size: 1rem;
    line-height: 1.55;
  }
  .svc-nav--dark .svc-nav__lead { color: var(--color-neutral-300); }

  /* Divided-cells grid: 1px gap on a neutral background draws the internal
     dividers automatically — the "letterhead / formal document" pattern. */
  .svc-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-neutral-200);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .svc-nav--dark .svc-nav__list {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .svc-nav__item {
    margin: 0;
    display: flex;
  }

  .svc-nav__cell {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.35rem 1.1rem;
    background: #fff;
    color: inherit;
    width: 100%;
    transition: background-color 180ms ease;
  }
  .svc-nav--dark .svc-nav__cell {
    background: var(--color-primary-950);
  }
  .svc-nav__cell:hover {
    background: var(--color-neutral-50);
  }
  .svc-nav--dark .svc-nav__cell:hover {
    background: var(--color-primary-900);
  }
  .svc-nav__cell:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: -2px;
    background: var(--color-neutral-50);
  }
  .svc-nav--dark .svc-nav__cell:focus-visible {
    background: var(--color-primary-900);
  }

  .svc-nav__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--color-primary-700);
    transition: color 180ms ease;
  }
  .svc-nav--dark .svc-nav__icon { color: var(--color-accent-400); }
  .svc-nav__cell:hover .svc-nav__icon { color: var(--color-accent-600); }
  .svc-nav--dark .svc-nav__cell:hover .svc-nav__icon { color: var(--color-accent-300); }

  .svc-nav__name {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.45vw, 1.4rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--color-primary-900);
    margin: 0.1rem 0 0;
    letter-spacing: -0.005em;
  }
  .svc-nav--dark .svc-nav__name { color: #fff; }

  .svc-nav__tag {
    color: var(--color-neutral-700);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .svc-nav--dark .svc-nav__tag { color: var(--color-neutral-300); }

  .svc-nav__arrow {
    margin-top: auto;
    padding-top: 0.4rem;
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    color: var(--color-primary-700);
    transition: color 180ms ease;
  }
  .svc-nav--dark .svc-nav__arrow { color: var(--color-accent-400); }
  .svc-nav__cell:hover .svc-nav__arrow { color: var(--color-accent-600); }
  .svc-nav--dark .svc-nav__cell:hover .svc-nav__arrow { color: var(--color-accent-300); }

  /* Responsive column counts, tuned for changing service counts. */
  @media (min-width: 640px) {
    .svc-nav__list[data-count="3"],
    .svc-nav__list[data-count="4"],
    .svc-nav__list[data-count="5"],
    .svc-nav__list[data-count="6"],
    .svc-nav__list[data-count="7"] {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .svc-nav__list[data-count="3"] {
      grid-template-columns: repeat(3, 1fr);
    }
    .svc-nav__list[data-count="4"] {
      grid-template-columns: repeat(4, 1fr);
    }
    .svc-nav__list[data-count="5"] {
      grid-template-columns: repeat(3, 1fr);
    }
    .svc-nav__list[data-count="6"],
    .svc-nav__list[data-count="7"] {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .svc-nav__list[data-count="5"] {
      grid-template-columns: repeat(5, 1fr);
    }
    .svc-nav__list[data-count="6"] {
      grid-template-columns: repeat(3, 1fr);
    }
    .svc-nav__list[data-count="7"] {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-nav__cell,
    .svc-nav__icon,
    .svc-nav__arrow {
      transition: none;
    }
  }
</style>
