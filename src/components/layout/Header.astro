---
import { business, navigation } from "../../data";
import Button from "../ui/Button.astro";
import Icon from "../ui/Icon.astro";
import MobileMenu from "./MobileMenu.astro";

const logoSrc = "/images/Speed%20Recovery%20Logo.svg";
---

<header class="site-header">
  <div class="container-page site-header__inner">
    <a href="/" class="brand" aria-label={business.shortName}>
      <img src={logoSrc} alt={business.shortName} class="brand__logo" loading="eager" decoding="async" />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {navigation.primary.map((item) => (
          item.children ? (
            <li class="primary-nav__item primary-nav__item--has-sub" data-has-sub>
              <a href={item.href} class="primary-nav__link">{item.label}</a>
              <button
                type="button"
                class="primary-nav__toggle"
                aria-label={`Show ${item.label.toLowerCase()} menu`}
                aria-expanded="false"
                data-dropdown-toggle
              >
                <Icon name="chevron-down" size={16} />
              </button>
              <div class="primary-nav__sub" role="menu">
                <a href={item.href} class="primary-nav__sub-all">
                  All {item.label.toLowerCase()}
                  <Icon name="arrow-right" size={14} />
                </a>
                <ul>
                  {item.children.map((child) => (
                    <li><a href={child.href} role="menuitem">{child.label}</a></li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li class="primary-nav__item">
              <a href={item.href} class="primary-nav__link">{item.label}</a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <Button href={business.phone.href} variant="primary" iconBefore="phone">
        {business.phone.display}
      </Button>
    </div>

    <button
      type="button"
      class="menu-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      data-mobile-menu-toggle
    >
      <Icon name="menu" size={24} />
    </button>
  </div>
</header>

<MobileMenu />

<script>
  import "../../scripts/mobileMenu";
  import "../../scripts/navDropdowns";
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #fff;
    border-bottom: 3px solid var(--color-accent-500);
    color: var(--color-primary-900);
    box-shadow: 0 8px 24px -20px rgba(0, 0, 0, 0.45);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.45rem;
  }

  .brand {
    display: flex;
    align-items: center;
    margin-right: auto;
  }
  .brand__logo {
    display: block;
    width: clamp(164px, 13.6vw, 220px);
    height: auto;
    object-fit: contain;
  }

  .primary-nav ul {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 1.25rem;
  }

  .primary-nav__item {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }

  .primary-nav__link {
    font-weight: 600;
    color: var(--color-primary-900);
    font-size: 1rem;
    padding-block: 0.5rem;
  }
  .primary-nav__link:hover,
  .primary-nav__item--has-sub:hover .primary-nav__link,
  .primary-nav__item--has-sub:focus-within .primary-nav__link {
    color: var(--color-accent-400);
  }

  .primary-nav__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 0;
    padding: 0.35rem 0.25rem;
    color: var(--color-primary-700);
    cursor: pointer;
    line-height: 0;
    transition: color 160ms ease, transform 160ms ease;
  }
  .primary-nav__item--has-sub:hover .primary-nav__toggle,
  .primary-nav__item--has-sub:focus-within .primary-nav__toggle,
  .primary-nav__item--has-sub[data-open="true"] .primary-nav__toggle {
    color: var(--color-accent-400);
    transform: rotate(180deg);
  }

  .primary-nav__sub {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    background: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 28px -12px rgba(0, 0, 0, 0.14);
    padding: 0.4rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 160ms ease, visibility 160ms ease, transform 160ms ease;
    z-index: 5;
  }
  .primary-nav__item--has-sub:hover .primary-nav__sub,
  .primary-nav__item--has-sub:focus-within .primary-nav__sub,
  .primary-nav__item--has-sub[data-open="true"] .primary-nav__sub {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .primary-nav__sub-all {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-primary-700);
    border-bottom: 1px solid var(--color-neutral-200);
    margin-bottom: 0.25rem;
  }
  .primary-nav__sub-all:hover { color: var(--color-accent-600); }

  .primary-nav__sub ul {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .primary-nav__sub li a {
    display: block;
    padding: 0.55rem 0.75rem;
    color: var(--color-primary-900);
    font-weight: 600;
    font-size: 1rem;
    border-radius: var(--radius-xs);
    transition: background-color 140ms ease, color 140ms ease;
  }
  .primary-nav__sub li a:hover,
  .primary-nav__sub li a:focus-visible {
    background: var(--color-neutral-50);
    color: var(--color-accent-600);
  }

  .header-cta {
    display: none;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-primary-200);
    padding: 0.55rem;
    border-radius: var(--radius-sm);
    color: var(--color-primary-900);
    cursor: pointer;
  }
  .menu-toggle:hover {
    background: var(--color-primary-50);
  }

  @media (min-width: 768px) {
    .primary-nav ul { display: flex; }
    .menu-toggle { display: none; }
  }

  @media (min-width: 1024px) {
    .header-cta { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .primary-nav__sub,
    .primary-nav__toggle {
      transition: none;
    }
  }
</style>
