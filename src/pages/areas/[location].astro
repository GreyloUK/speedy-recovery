---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import Hero from "../../components/sections/Hero.astro";
import TrustRibbon from "../../components/sections/TrustRibbon.astro";
import LocationDetail from "../../components/sections/LocationDetail.astro";
import NapCard from "../../components/sections/NapCard.astro";
import ServicesNav from "../../components/sections/ServicesNav.astro";
import PhoneCTA from "../../components/sections/PhoneCTA.astro";
import ReviewsGoogle from "../../components/sections/ReviewsGoogle.astro";
import FAQ from "../../components/sections/FAQ.astro";
import AreasCovered from "../../components/sections/AreasCovered.astro";
import { locations, sharedFaqs } from "../../data";
import type { Location } from "../../data/locations";
import {
  breadcrumbSchema,
  faqSchema,
  locationLocalBusinessSchema,
} from "../../utils/schema";
import { composeTitle } from "../../utils/seo";

export async function getStaticPaths() {
  return locations.map((l) => ({
    params: { location: l.slug },
    props: { location: l },
  }));
}

interface Props {
  location: Location;
}

const { location } = Astro.props;

const baseLocation = location.basedAt
  ? locations.find((l) => l.slug === location.basedAt)
  : undefined;

const pageSeo: Record<string, { title: string; description: string; heroTitle: string }> = {
  harrow: {
    title: "Car Recovery Harrow — 24/7 Vehicle Recovery",
    description:
      "24/7 car recovery in Harrow, North Harrow and HA postcodes. PAS43 certified, O-Licence holder, secure yard and 20-min typical response.",
    heroTitle: "Car Recovery Harrow — 24/7",
  },
  perivale: {
    title: "Car Recovery Perivale & Perivale Car Pound Help",
    description:
      "Car recovery in Perivale, UB6 and help collecting from Perivale car pound. 24/7 flatbed recovery from Speedy Recovery's Walmgate Road base.",
    heroTitle: "Car Recovery Perivale & Perivale Car Pound Help",
  },
  greenford: {
    title: "Car Recovery Greenford — 24/7 Vehicle Recovery",
    description:
      "24/7 car recovery in Greenford, UB6, A40 and nearby industrial estates. Dispatched from Perivale with 15-min typical response.",
    heroTitle: "Car Recovery Greenford — 24/7",
  },
  ealing: {
    title: "Car Recovery Ealing — 24/7 Vehicle Recovery",
    description:
      "24/7 car recovery in Ealing, W5, W13, Ealing Broadway, West Ealing and Hanger Lane. Dispatched from Perivale, PAS43 certified.",
    heroTitle: "Car Recovery Ealing — 24/7",
  },
  hayes: {
    title: "Car Recovery Hayes — 24/7 Vehicle Recovery",
    description:
      "24/7 car recovery in Hayes, UB3, Heathrow corridor, A312 and A4. Flatbed recovery for cars, vans and light commercials.",
    heroTitle: "Car Recovery Hayes — 24/7",
  },
};

const seo = pageSeo[location.slug] ?? {
  title: `Vehicle Recovery in ${location.name} — 24/7`,
  description: `24/7 vehicle recovery in ${location.name} — ${location.postcode} and surrounding postcodes. ${location.responseMinutes}-min average response. PAS43 certified. Call us.`,
  heroTitle: `24/7 vehicle recovery in ${location.name}.`,
};

const title = composeTitle(seo.title);
const description = seo.description;

const combinedFaqs = [...location.faqs, ...sharedFaqs.slice(0, 2)];

const heroLead = location.basedAt && baseLocation
  ? `Dispatched from our ${baseLocation.name} base — typical response ${location.responseMinutes} minutes. PAS43, O-Licence, IVR.`
  : `Operating from ${location.address.locality} — typical response ${location.responseMinutes} minutes. PAS43, O-Licence, IVR.`;

const schema = [
  faqSchema(combinedFaqs),
  breadcrumbSchema([
    { label: "Home", path: "/" },
    { label: "Areas", path: "/areas/" },
    { label: location.name, path: `/areas/${location.slug}/` },
  ]),
];
if (!location.basedAt) {
  schema.unshift(locationLocalBusinessSchema(location));
}
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/areas/${location.slug}/`}
  schema={schema}
>
  <div class="container-page breadcrumb-band-tight">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Areas", href: "/areas/" },
        { label: location.name },
      ]}
    />
  </div>

  <Hero
    variant="location"
    eyebrow={`${location.name} · ${location.postcode}`}
    title={seo.heroTitle}
    lead={heroLead}
    image={location.heroImage}
    imageAlt={`Recovery vehicle on scene in ${location.name}`}
  />

  <TrustRibbon />

  <LocationDetail location={location} />

  <PhoneCTA
    tone="emergency"
    heading={`On the roadside in ${location.name}?`}
    lead="One call and a flatbed is on the way."
  />

  <ServicesNav
    heading={`Services available in ${location.name}`}
    eyebrow={location.basedAt && baseLocation ? `Dispatched from ${baseLocation.name}` : "What we handle from this base"}
    filterSlugs={location.servicesOffered}
  />

  <ReviewsGoogle />

  <AreasCovered excludeSlug={location.slug} />

  <FAQ items={combinedFaqs} heading={`${location.name} — common questions.`} />

  {location.basedAt ? (
    <PhoneCTA tone="navy" />
  ) : (
    <NapCard location={location} />
  )}
</BaseLayout>
