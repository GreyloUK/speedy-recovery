---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import aboutTeamImage from "../assets/images/about-team.jpg";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import TrustRibbon from "../components/sections/TrustRibbon.astro";
import FleetStats from "../components/sections/FleetStats.astro";
import PhoneCTA from "../components/sections/PhoneCTA.astro";
import ReviewsGoogle from "../components/sections/ReviewsGoogle.astro";
import { breadcrumbSchema } from "../utils/schema";
import { composeTitle } from "../utils/seo";

const title = composeTitle("About Us — Vehicle Recovery London + M25");
const description = "Family-run vehicle recovery across London + M25 — PAS43 certified, O-Licence, 6-vehicle fleet out of Harrow. See how we run 24/7 recovery work. Call now.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/about/"
  schema={breadcrumbSchema([
    { label: "Home", path: "/" },
    { label: "About", path: "/about/" },
  ])}
>
  <div class="container-page breadcrumb-band">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "About" }]} />
  </div>

  <section class="about">
    <div class="container-page about__inner">
      <div class="about__content">
        <span class="section-label">About</span>
        <h1>Family-run vehicle recovery across London + M25 — not a call-centre middleman.</h1>

        <div class="about__body">
          <p class="about__lead">
            Speedy Recovery is a family-run vehicle recovery operator founded
            in 1995, based in North Harrow and serving London + M25 twenty-four
            hours a day, every day of the year. The yard, the trucks and the
            drivers are all ours — no subcontracting, no call-centre routing,
            no "partner" network with a faceless dispatch fee baked into your
            quote.
          </p>

          <p>
            The business is now in its second generation, with Sam Shafi taking
            over from his dad and continuing the same hands-on approach: answer
            the phone, send the right truck and keep the customer informed. The
            operation grew the way serious trade businesses do: one insurer
            contract, one garage relationship, one police-pound clearance at a
            time. Today we run six recovery vehicles — including a 7.5-ton
            recovery truck for heavier and/or loaded vehicles, plus a HIAB for
            commercial jobs — dispatched from our registered yard at Cardoc
            House in North Harrow and our operating point on Walmgate Road,
            Perivale.
          </p>

          <p>
            The credentials that matter for the work are in place and in date.
            We hold <strong>PAS43 2012 certification</strong> — the British
            Standard insurer panels require before they'll assign a claim.
            We're a full <strong>O-Licence holder</strong> and every driver
            we employ is <strong>IVR-certified</strong>, which is what police
            pounds and fleet dispatchers check before they'll release a
            vehicle into your custody. We work directly with
            <strong>the AA, FMG</strong> and a network of local garages across
            north-west and west London, with London + M25 coverage.
          </p>

          <p>
            What it means for you: when you call, you speak to the operator
            who's dispatching the truck, not a triage desk hundreds of miles
            away. The quote you're given on the phone is the one we hold to.
            The driver who arrives works for us. And because we're running
            our own fleet, not borrowing one, we can say yes to jobs other
            operators quietly decline — 2am motorway incidents, keyless
            EVs, heavy commercials, vehicles needing a week in secure storage
            while an insurer catches up.
          </p>
        </div>
      </div>

      <aside class="about__media" aria-hidden="true">
        <figure>
          <Image
            src={aboutTeamImage}
            alt="Speedy Recovery driver at the Harrow yard"
            loading="lazy"
            decoding="async"
            widths={[360, 520, 720, 900]}
            sizes="(min-width: 900px) 36vw, calc(100vw - 2.5rem)"
            quality="mid"
          />
          <figcaption>
            <span class="about__caption-label">On the yard</span>
            <span class="about__caption-text">Harrow, HA2 6AE</span>
          </figcaption>
        </figure>
      </aside>
    </div>
  </section>

  <TrustRibbon />

  <FleetStats />

  <ReviewsGoogle />

  <PhoneCTA tone="navy" />
</BaseLayout>

<style>
  .about {
    background: #fff;
  }
  .about__inner {
    padding-block: 2.5rem 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    align-items: start;
  }

  .about__content h1 {
    margin-top: 0.6rem;
    max-width: 22ch;
  }

  .about__body {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 62ch;
  }

  .about__body p {
    color: var(--color-neutral-800);
    line-height: 1.7;
    font-size: 1.02rem;
    margin: 0;
  }

  .about__lead {
    font-size: 1.15rem !important;
    color: var(--color-primary-900) !important;
    line-height: 1.55 !important;
    font-weight: 500;
  }

  .about__body strong {
    color: var(--color-primary-900);
    font-weight: 700;
  }

  /* ---- Media column ---- */
  .about__media figure {
    margin: 0;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-neutral-200);
    box-shadow: var(--shadow-hover);
  }
  .about__media img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .about__media figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0.9rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    color: #fff;
    background: linear-gradient(
      to top,
      rgba(11, 14, 28, 0.85) 0%,
      rgba(11, 14, 28, 0.55) 55%,
      rgba(11, 14, 28, 0) 100%
    );
  }
  .about__caption-label {
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-accent-400);
  }
  .about__caption-text {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.005em;
  }

  @media (min-width: 900px) {
    .about__inner {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: 3rem;
      padding-block: 3.5rem 4.5rem;
    }
    .about__media {
      position: sticky;
      top: 6rem;
    }
  }
</style>
