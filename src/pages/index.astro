---
import BaseLayout from "../layouts/BaseLayout.astro";
import homeHeroImage from "../assets/images/recovery-van-recovery.jpeg";
import Hero from "../components/sections/Hero.astro";
import TrustRibbon from "../components/sections/TrustRibbon.astro";
import WhyChooseUs from "../components/sections/WhyChooseUs.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import ServicesNav from "../components/sections/ServicesNav.astro";
import Process from "../components/sections/Process.astro";
import FleetStats from "../components/sections/FleetStats.astro";
import Credentials from "../components/sections/Credentials.astro";
import ReviewsGoogle from "../components/sections/ReviewsGoogle.astro";
import AreasCovered from "../components/sections/AreasCovered.astro";
import PhoneCTA from "../components/sections/PhoneCTA.astro";
import FAQ from "../components/sections/FAQ.astro";
import { sharedFaqs, seo } from "../data";
import { localBusinessSchema, faqSchema } from "../utils/schema";
---

<BaseLayout
  title={seo.defaultTitle}
  description={seo.defaultDescription}
  canonicalPath="/"
  schema={[localBusinessSchema(), faqSchema(sharedFaqs)]}
>
  <Hero
    variant="home"
    eyebrow="24/7 · London + M25"
    title="24/7 Vehicle Recovery across London + M25"
    lead="Stuck on the roadside, recovering after a crash, arranging police pound release or moving a specialist vehicle? Speedy Recovery runs its own fleet, its own drivers and a 25-minute average response across London + M25. PAS43 certified, O-Licence holder, IVR-trained operators, direct AA and FMG partner, with secure storage and business recovery support available around the clock."
    image={homeHeroImage}
    imageAlt="Speedy Recovery flatbed truck carrying a car on a London street."
  />

  <TrustRibbon />

  <WhyChooseUs />

  <ServicesNav
    eyebrow="What we handle"
    heading="Core services. One operator. All 24/7."
    lead="Breakdowns, accidents, police pounds, specialist vehicles, repossession, prestige transport and secure storage — handled by our own fleet and drivers."
  />

  <PhoneCTA
    tone="emergency"
    heading="On a hard shoulder? Call now."
    lead="No out-of-hours surcharge. No callback. No meter running."
  />

  <Process />

  <FleetStats />

  <Credentials />

  <ReviewsGoogle />

  <ServiceGrid />

  <AreasCovered />

  <FAQ items={sharedFaqs} />

  <PhoneCTA
    tone="navy"
    heading="One call, fixed quote, flatbed dispatched."
    lead="If your vehicle has stopped moving — anywhere across London + M25, any hour of the day — we can help right now."
  />
</BaseLayout>
