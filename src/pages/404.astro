---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import { business } from "../data";
import { composeTitle } from "../utils/seo";

const title = composeTitle("Page not found");
const description = "The page you were looking for doesn't exist. If you need vehicle recovery now, call us directly.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/404/"
  noindex={true}
>
  <section class="not-found container-page">
    <span class="section-label">404</span>
    <h1>That page isn't here.</h1>
    <p>
      The URL you've followed doesn't exist on our site. If you need recovery now,
      the fastest route is always the phone.
    </p>

    <div class="not-found__actions">
      <Button href={business.phone.href} variant="primary" size="lg" iconBefore="phone">
        Call {business.phone.display}
      </Button>
      <Button href="/" variant="secondary" size="lg" iconAfter="arrow-right">
        Back to home
      </Button>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: 4rem 5rem;
    text-align: left;
    max-width: 56ch;
  }
  .not-found h1 { margin-top: 0.6rem; }
  .not-found p {
    margin-top: 0.75rem;
    color: var(--color-neutral-700);
    line-height: 1.55;
    font-size: 1.05rem;
  }
  .not-found__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
